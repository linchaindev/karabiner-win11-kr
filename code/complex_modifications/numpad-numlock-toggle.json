{
    "title": "Numpad NumLock Toggle (숫자 ↔ 커서 모드)",
    "rules": [
        {
            "description": "NumLock/Clear 키로 키패드 모드 토글 (알림 표시)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "keypad_num_lock",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "conditions": [
                        {
                            "type": "variable_if",
                            "name": "numpad_nav",
                            "value": 1
                        }
                    ],
                    "to": [
                        {
                            "set_variable": {
                                "name": "numpad_nav",
                                "value": 0
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "numpad_mode",
                                "text": "Numpad: 숫자 모드"
                            }
                        }
                    ],
                    "parameters": {
                        "basic.to_delayed_action_delay_milliseconds": 1500
                    },
                    "to_delayed_action": {
                        "to_if_invoked": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
