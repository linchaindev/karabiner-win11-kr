{
    "title": "Numpad NumLock Toggle (number ↔ cursor mode)",
    "rules": [
        {
            "description": "Toggle keypad mode with NumLock/Clear (shows a notification)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "keypad_num_lock",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "conditions": [
                        {
                            "type": "variable_if",
                            "name": "numpad_nav",
                            "value": 1
                        }
                    ],
                    "to": [
                        {
                            "set_variable": {
                                "name": "numpad_nav",
                                "value": 0
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "numpad_mode",
                                "text": "Numpad: Number mode"
                            }
                        }
                    ],
                    "parameters": {
                        "basic.to_delayed_action_delay_milliseconds": 1500
                    },
                    "to_delayed_action": {
                        "to_if_invoked": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
                        ],
                        "to_if_canceled": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
                        ]
                    }
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "keypad_num_lock",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "numpad_nav",
                                "value": 1
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "numpad_mode",
                                "text": "Numpad: Cursor mode"
                            }
                        }
                    ],
                    "parameters": {
                        "basic.to_delayed_action_delay_milliseconds": 1500
                    },
                    "to_delayed_action": {
                        "to_if_invoked": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
                        ],
                        "to_if_canceled": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
                        ]
                    }
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "keypad_clear",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "conditions": [
                        {
                            "type": "variable_if",
                            "name": "numpad_nav",
                            "value": 1
                        }
                    ],
                    "to": [
                        {
                            "set_variable": {
                                "name": "numpad_nav",
                                "value": 0
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "numpad_mode",
                                "text": "Numpad: Number mode"
                            }
                        }
                    ],
                    "parameters": {
                        "basic.to_delayed_action_delay_milliseconds": 1500
                    },
                    "to_delayed_action": {
                        "to_if_invoked": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
                        ],
                        "to_if_canceled": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
                        ]
                    }
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "keypad_clear",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "numpad_nav",
                                "value": 1
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "numpad_mode",
                                "text": "Numpad: Cursor mode"
                            }
                        }
                    ],
                    "parameters": {
                        "basic.to_delayed_action_delay_milliseconds": 1500
                    },
                    "to_delayed_action": {
                        "to_if_invoked": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
                        ],
                        "to_if_canceled": [
                            {
                                "set_notification_message": {
                                    "id": "numpad_mode",
                                    "text": ""
                                }
                            }
                        ]
                    }
                }
            ]
        },
