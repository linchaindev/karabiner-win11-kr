{
    "title": "F-key short/long dual action",
    "rules": [
        {
            "description": "F1–F12: tap = function key, hold (200ms) = brightness/volume/media (F6 excluded)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "f1",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to_if_alone": [
                        {
                            "key_code": "f1"
                        }
                    ],
                    "to_if_held_down": [
                        {
                            "consumer_key_code": "display_brightness_decrement"
                        }
                    ],
                    "parameters": {
                        "basic.to_if_alone_timeout_milliseconds": 200,
                        "basic.to_if_held_down_threshold_milliseconds": 200
                    }
                },
