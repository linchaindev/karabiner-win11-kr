{
    "title": "Windows-style Ctrl shortcuts v3 (A/Z/Y/S/F/N/T/W/P/R/L/O/C/X/V, Finder move support, terminals Â· IDEs excluded)",
    "rules": [
        {
            "description": "[Priority 1] Finder: Ctrl+C copy / Ctrl+X cut / Ctrl+V paste Â· move",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "c",
                        "modifiers": {
                            "mandatory": [
                                "control"
                            ],
                            "optional": [
                                "caps_lock"
                            ]
                        }
                    },
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.apple\\.finder$"
                            ]
                        }
                    ],
                    "to": [
                        {
                            "key_code": "c",
                            "modifiers": [
                                "left_command"
                            ]
                        },
                        {
                            "set_variable": {
                                "name": "finder_cut",
                                "value": 0
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "finder_cut",
                                "text": ""
                            }
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "x",
                        "modifiers": {
                            "mandatory": [
                                "control"
                            ],
                            "optional": [
                                "caps_lock"
                            ]
                        }
                    },
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.apple\\.finder$"
                            ]
                        }
                    ],
                    "to": [
                        {
                            "key_code": "c",
                            "modifiers": [
                                "left_command"
                            ]
                        },
                        {
                            "set_variable": {
                                "name": "finder_cut",
                                "value": 1
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "finder_cut",
                                "text": "Cut â€” paste to move"
                            }
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "v",
                        "modifiers": {
                            "mandatory": [
                                "control"
                            ],
                            "optional": [
                                "caps_lock"
                            ]
                        }
                    },
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.apple\\.finder$"
                            ]
                        },
                        {
                            "type": "variable_if",
                            "name": "finder_cut",
                            "value": 1
                        }
                    ],
                    "to": [
                        {
                            "key_code": "v",
                            "modifiers": [
                                "left_command",
                                "left_option"
                            ]
                        },
                        {
                            "set_variable": {
                                "name": "finder_cut",
                                "value": 0
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "finder_cut",
                                "text": ""
                            }
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "v",
                        "modifiers": {
                            "mandatory": [
                                "control"
                            ],
                            "optional": [
                                "caps_lock"
                            ]
